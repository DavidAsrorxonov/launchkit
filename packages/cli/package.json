{
  "name": "create-launchkit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "create-launchkit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:smoke": "npm run build -w @launchkit/schema && npm run build -w @launchkit/generator && npm run build && vitest run --config vitest.smoke.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@launchkit/generator": "0.0.0",
    "@launchkit/schema": "0.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
