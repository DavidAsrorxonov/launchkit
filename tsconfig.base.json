{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@baseforge/schema": ["./packages/schema/src"],
      "@baseforge/generator": ["./packages/generator/src"],
      "@baseforge/shared": ["./packages/shared/src"],
      "@baseforge/templates": ["./packages/templates/src"]
    }
  }
}
